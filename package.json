  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "anchor test",
    "test:vault": "anchor test -- --grep 'loop-vault'",
    "test:cred": "anchor test -- --grep 'loop-cred'",
    "test:oxo": "anchor test -- --grep 'loop-oxo'",
    "test:vtp": "anchor test -- --grep 'loop-vtp'",
    "test:avp": "anchor test -- --grep 'loop-avp'",
    "test:integration": "anchor test -- --grep 'Loop Protocol Integration'"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.8",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.0.0"
  }
