{
  "manifest_version": 3,
  "name": "Loop Capture",
  "version": "0.1.0",
  "description": "Capture value from your online activity. Earn from referrals, attention, and more.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.ebay.com/*",
    "https://*.walmart.com/*",
    "https://*.target.com/*",
    "https://*.bestbuy.com/*",
    "https://*.homedepot.com/*",
    "https://*.lowes.com/*",
    "https://*.newegg.com/*",
    "https://*.shopify.com/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
